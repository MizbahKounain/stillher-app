# =============================================================================
# python-dotenv + Flask (this project)
# =============================================================================
# The app calls load_dotenv() at the top of app/config.py before the Config
# class is defined. That reads THIS file from the project root and loads
# NAME=value pairs into os.environ. Config then picks up EMAIL_USER and
# EMAIL_PASS via os.environ.get(...) — no need to change Config when you add
# variables here.
#
# Run the app from the project root (where this file lives) so load_dotenv()
# finds it. To use another path: load_dotenv("/path/to/.env") in config.py.
#
# Install: pip install python-dotenv
# Security: do not commit real secrets; keep .env out of git (.gitignore).
# =============================================================================

